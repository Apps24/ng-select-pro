{
  "name": "ng-select-pro-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo-app",
    "build": "ng build",
    "build:lib": "ng build ng-select-pro --configuration production && node -e \"const fs=require('fs');const path=require('path');fs.copyFileSync('README.md','dist/ng-select-pro/README.md');fs.copyFileSync('CHANGELOG.md','dist/ng-select-pro/CHANGELOG.md');fs.mkdirSync('dist/ng-select-pro/docs',{recursive:true});fs.readdirSync('docs').forEach(f=>fs.copyFileSync(path.join('docs',f),path.join('dist/ng-select-pro/docs',f)));console.log('Assets copied to dist')\"",
    "test": "ng test ng-select-pro --watch=false --browsers=ChromeHeadless",
    "test:demo": "ng test demo-app --watch=false --browsers=ChromeHeadless",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/cdk": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^17.0.0",
    "typescript": "~5.2.0"
  }
}
